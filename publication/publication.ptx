<?xml version="1.0" encoding="UTF-8" ?>
<publication>
    <!-- directories are relative to the main source PreTeXt file -->
    <source>
        <directories external="../assets" generated="../generated-assets"/>
    </source>
    
    <common>
        <!-- When writing an article for a specific journal, you can   -->
        <!-- specify the name of the journal to get appropriate latex. -->
        <!-- See the guide for a list of valid names:
          https://pretextbook.org/doc/guide/html/appendix-journals.html#appendix-journals -->

        <!--<journal name="ams" /> -->
    </common>

    <html favicon="simple" embed-button="yes">
      <css theme="denver" color-main="#003087"/> <!-- Tech blue main color -->
      <knowl example="no"/>
    </html>
</publication>
